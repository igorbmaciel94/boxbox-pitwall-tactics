# BoxBox Pitwall Tactics - Production Environment Variables

# JWT signing secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_A_STRONG_SECRET

# CORS origin for the frontend
CORS_ORIGIN=https://boxbox.lighthousedev.uk

# ASP.NET environment
ASPNETCORE_ENVIRONMENT=Production

# Docker image tag (set by CI or manually)
BOXBOX_IMAGE_TAG=main
